# Server
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173
# Comma-separated origins. Example for online backend + local V3 debugging:
# CORS_ORIGIN=https://www.example.com,http://localhost:5173,http://127.0.0.1:5173
CORS_ORIGIN=http://localhost:5173
# In production, CORS_ORIGIN or FRONTEND_URL is required because credentials are enabled.
# In non-production, localhost/127.0.0.1/::1 origins are allowed unless CORS_ALLOW_LOCALHOST=false.
CORS_ALLOW_LOCALHOST=true
JWT_SECRET=replace-with-a-long-random-secret

# Database
DB_HOST=127.0.0.1
DB_NAME=jack_house
DB_USER=root
DB_PASSWORD=

# Analytics
ANALYTICS_ENABLED=true
ANALYTICS_ENABLE_STATS=true
ANALYTICS_AUTO_MIGRATE=true
ANALYTICS_APPS=jack-house-v3
# Defaults to the main DB settings when omitted.
# ANALYTICS_DB_HOST=127.0.0.1
# ANALYTICS_DB_NAME=jack_house
# ANALYTICS_DB_USER=root
# ANALYTICS_DB_PASSWORD=
ANALYTICS_DB_CONNECTION_LIMIT=5

# MinIO fallback storage
MINIO_ENDPOINT=127.0.0.1
MINIO_PORT=9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_POSTFILES_BUCKET=post-files
MINIO_HOMEIMG_BUCKET=home-img
MINIO_RICHTEXT_BUCKET=rich-text
MINIO_BG_BUCKET=event-bg
MINIO_BADGES_BUCKET=badges

# GitHub storage: token stays on backend only.
# Owner/repo default to 1skyyks1/jack-house-img in code, but keep them explicit in production.
GITHUB_STORAGE_TOKEN=
GITHUB_STORAGE_OWNER=1skyyks1
GITHUB_STORAGE_REPO=jack-house-img
GITHUB_STORAGE_BRANCH=main
GITHUB_STORAGE_CDN=jsdelivr

# Public rich text images: sharp -> webp -> short hash name -> GitHub -> jsDelivr.
# URL shape: https://cdn.jsdelivr.net/gh/1skyyks1/jack-house-img/content/rich-text/<16-char-hash>.webp
RICHTEXT_STORAGE_PROVIDER=github
RICHTEXT_STORAGE_BUCKET=rich-text
RICHTEXT_GITHUB_STORAGE_BASE_PATH=content
# Rich text cleanup is dry-run by default. Set false only for a scheduled trusted job.
RICHTEXT_ASSET_CLEANUP_RETENTION_DAYS=7
RICHTEXT_ASSET_CLEANUP_LIMIT=100
RICHTEXT_ASSET_CLEANUP_DRY_RUN=true
# One-time history backfill is also dry-run by default.
RICHTEXT_ASSET_BACKFILL_BATCH_SIZE=100
RICHTEXT_ASSET_BACKFILL_DRY_RUN=true

# Admin-uploaded public badge images.
BADGES_STORAGE_PROVIDER=github
BADGES_STORAGE_BUCKET=badges
BADGES_GITHUB_STORAGE_BASE_PATH=content

# Event stage background images.
EVENT_STAGE_BG_STORAGE_PROVIDER=github
EVENT_STAGE_BG_STORAGE_BUCKET=event-stage-bg
EVENT_STAGE_BG_GITHUB_STORAGE_BASE_PATH=content

# Post submissions: no compression and no format conversion.
# Object name is short hash prefix + original extension; full sha256 is stored in DB.
POSTFILES_STORAGE_PROVIDER=github
POSTFILES_STORAGE_BUCKET=post-files
POSTFILES_GITHUB_STORAGE_BASE_PATH=submissions

# Upload limits
RICHTEXT_IMAGE_MAX_SIZE_MB=5
POSTFILE_MAX_SIZE_MB=20
POSTFILE_MAX_TOTAL_SIZE_MB=100
POSTFILE_ALLOWED_EXTENSIONS=.jpg,.jpeg,.png,.gif,.webp,.zip,.rar,.7z,.osz,.osk,.osr,.osu,.pdf,.txt,.md,.json,.csv,.xlsx,.xls
# POSTFILE_ALLOWED_MIME_TYPES=
EVENT_STAGE_BG_MAX_SIZE_MB=1

# Public image optimization. This does not apply to post submissions.
IMAGE_OPTIMIZE_ENABLED=true
IMAGE_OPTIMIZE_CONVERT_WEBP=true
IMAGE_OPTIMIZE_MAX_WIDTH=2560
IMAGE_OPTIMIZE_MAX_HEIGHT=2560
IMAGE_OPTIMIZE_JPEG_QUALITY=82
IMAGE_OPTIMIZE_PNG_QUALITY=90
IMAGE_OPTIMIZE_WEBP_QUALITY=82

# Cookie auth migration
AUTH_COOKIE_NAME=jh_auth
CSRF_COOKIE_NAME=jh_csrf
AUTH_COOKIE_SAME_SITE=lax
# Set true in HTTPS production. Required when AUTH_COOKIE_SAME_SITE=none.
# If local V3 directly calls an online backend, the online backend must use
# AUTH_COOKIE_SAME_SITE=none and AUTH_COOKIE_SECURE=true, and CORS_ORIGIN must
# include http://localhost:5173 / http://127.0.0.1:5173.
AUTH_COOKIE_SECURE=false
